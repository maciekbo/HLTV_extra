{
  "name": "HLTV Extension",
  "description": "Customization and more stuff for HLTV",
  "version": "0.1.1",
  "manifest_version": 3,
  "icons": {
        "128":"icons/logo128.png",
        "48":"icons/logo48.png",
        "38":"icons/logo38.png",
        "19":"icons/logo19.png",
        "16":"icons/logo16.png"
  },
  "action": {
    "default_popup": "intro_popup.html",
    "default_icon": {
        "128":"icons/logo128.png",
        "48":"icons/logo48.png",
        "38":"icons/logo38.png",
        "19":"icons/logo19.png",
        "16":"icons/logo16.png"
    }
  },
  "content_scripts": [
    {
      "js": ["scripts/role_points_calc.js"],
      "matches": [
        "https://*.hltv.org/fantasy/*"
      ]
    },
    {
      "js": ["scripts/cleaner.js"],
      "matches": [
        "https://*.hltv.org/*"
      ]
    },
    {
      "js": ["scripts/pin_event_button.js"],
      "matches": [
        "https://*.hltv.org/events/*"
      ]
    },
    {
      "js": ["scripts/list_pinned_events.js"],
      "matches": [
        "https://*.hltv.org/"
      ]
    }
  ],
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "web_accessible_resources": [
  {
    "resources": ["images/*"],
    "matches": ["https://*.hltv.org/*"]
  }
]
}